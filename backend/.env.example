# ── Server ────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# ── Auth — generate a strong random string for production ─────
# Run: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this

# ── Database (Railway auto-provides this when you add Postgres) ─
DATABASE_URL=postgresql://user:password@host:5432/railway

# ── Email (Resend) ─────────────────────────────────────────────
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=DineXPOS <hello@dinexpos.in>
APP_URL=https://app.dinexpos.in

# ── Sentry (error monitoring) ──────────────────────────────────
# Get DSN from: sentry.io → New Project → Node.js → DSN
SENTRY_DSN=

# ── Razorpay ────────────────────────────────────────────────────
# Get from: Razorpay Dashboard → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
# Get from: Razorpay Dashboard → Settings → Webhooks → add webhook → copy secret
RAZORPAY_WEBHOOK_SECRET=
# After creating plans in Razorpay dashboard, paste the plan IDs here
RAZORPAY_PLAN_STARTER=
RAZORPAY_PLAN_PRO=
RAZORPAY_PLAN_ENTERPRISE=
