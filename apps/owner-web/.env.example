# Backend API URL — set this in Vercel project settings
VITE_API_BASE_URL=https://api.dinexpos.in/api/v1

# Sentry (error monitoring) — set in Vercel project settings
# Get DSN from: sentry.io → New Project → React/Browser → DSN
VITE_SENTRY_DSN=

# App version — used in Sentry release tracking
VITE_APP_VERSION=1.0.0
