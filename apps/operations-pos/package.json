{
  "name": "dinex-pos",
  "version": "1.0.0",
  "private": true,
  "description": "DineX POS Terminal",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "electron": "electron .",
    "electron:build": "vite build && electron-builder build --mac --win"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@vitejs/plugin-react": "^5.1.0",
    "electron": "32.3.3",
    "electron-builder": "^25.1.8",
    "jsdom": "^27.1.0",
    "vite": "^7.2.1",
    "vitest": "^4.0.7"
  },
  "build": {
    "appId": "in.dinexpos.pos",
    "productName": "DineX POS",
    "directories": {
      "output": "electron-dist"
    },
    "files": [
      "dist/**",
      "electron/**"
    ],
    "mac": {
      "category": "public.app-category.business",
      "icon": "public/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "icon": "public/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "electronVersion": "32.3.3"
  }
}