{
  "name": "dinex-pos",
  "version": "1.3.5",
  "private": true,
  "description": "Plato POS Terminal",
  "author": "Saisangeet Hospitality Pvt Ltd <hello@dinexpos.in>",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "electron": "electron .",
    "electron:build": "vite build && electron-builder build --mac --win",
    "electron:build:win": "vite build && electron-builder build --win",
    "electron:build:mac": "vite build && electron-builder build --mac",
    "release": "vite build && electron-builder --win --x64 && node scripts/gh-release.js"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "electron-updater": "^6.3.9",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@vitejs/plugin-react": "^5.1.0",
    "electron": "32.3.3",
    "electron-builder": "^25.1.8",
    "jsdom": "^27.1.0",
    "vite": "^7.2.1",
    "vitest": "^4.0.7"
  },
  "build": {
    "appId": "in.dinexpos.pos",
    "productName": "Plato POS",
    "directories": {
      "output": "electron-dist"
    },
    "files": [
      "dist/**",
      "electron/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "yathuramarnath-sys",
      "repo": "saisangeet"
    },
    "mac": {
      "category": "public.app-category.business",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "artifactName": "Plato-POS-Setup.exe"
    },
    "electronVersion": "32.3.3"
  }
}
