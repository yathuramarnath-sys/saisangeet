package-lock.json
apps/*/package-lock.json
node_modules/
apps/*/node_modules/
packages/*/node_modules/
electron-dist/
electron-dist/
.claude/

# Local dev env overrides — these point to localhost and must NEVER be committed
# In dev: apps use http://localhost:4000/api/v1 (safe, isolated)
# In production: apps use the .env file (https://api.dinexpos.in/api/v1)
.env.local
apps/*/.env.local

# Android release keystores — sensitive signing keys, never commit binaries
# The KEYSTORE_INFO.md readme IS committed (no secrets, just instructions)
backend/keystores/*.jks
backend/keystores/*.keystore

# Built release artifacts — too large for git, distribute via GitHub Releases
backend/keystores/releases/*.apk
backend/keystores/releases/*.exe
